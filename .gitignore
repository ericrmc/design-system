state/selvedge.sqlite
state/selvedge.sqlite-*
state/selvedge.sqlite.*backup
state/selvedge.sqlite.*backup-*
state/selvedge.db

# L3 boundary snapshots (DV-S081-1, OI-S081-3, S084).
# Inside workspace boundary, outside git boundary: runtime recoverability
# beats clone portability (codex-shape-consult Q3, S084).
state/snapshots/
state/tests/round-trip-spec/
state/tests/spec-bodies/
__pycache__/
*.pyc

# pytest / coverage artifacts (regenerable; not project state).
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Claude Code scheduled-tasks lockfile (per-process; not project state).
